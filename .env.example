# Copy this file to .env and fill in your values for local development.
# On Render, set these as Environment Variables in the dashboard.

# ── Supabase PostgreSQL connection string ──────────────────────────────────────
# Replace <YOUR-PASSWORD> with your actual Supabase DB password
# sslmode=require is mandatory for Supabase
DATABASE_URL=postgresql://postgres.eunkvnuoxijeokgwgkpy:<YOUR-PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a strong random string (at least 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRATION=86400000

# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── File uploads (local dev only; on Render files are ephemeral) ───────────────
FILE_UPLOAD_DIR=uploads/resumes

# ── Server port (Render sets this automatically) ──────────────────────────────
PORT=8080

